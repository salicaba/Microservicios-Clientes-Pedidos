services:
  # Base de datos MySQL para clientes
  mysql-clientes:
    image: mysql:8.0
    container_name: mysql-clientes
    environment:
      MYSQL_ROOT_PASSWORD: root123
      MYSQL_DATABASE: clientes_db
      MYSQL_USER: user_clientes
      MYSQL_PASSWORD: clientes123
    ports:
      - "127.0.0.1:3307:3306"
    volumes:
      - mysql_clientes_data:/var/lib/mysql
    networks:
      - microservices-network
    restart: unless-stopped

  # Base de datos PostgreSQL para pedidos
  postgres-pedidos:
    image: postgres:15
    container_name: postgres-pedidos
    environment:
      POSTGRES_DB: pedidos_db
      POSTGRES_USER: user_pedidos
      POSTGRES_PASSWORD: pedidos123
    ports:
      - "127.0.0.1:5433:5432"
    volumes:
      - postgres_pedidos_data:/var/lib/postgresql/data
    networks:
      - microservices-network
    restart: unless-stopped

  # RabbitMQ para mensajería
  rabbitmq:
    image: rabbitmq:3-management
    container_name: rabbitmq
    ports:
      - "127.0.0.1:5673:5672"
      - "127.0.0.1:15673:15672"
    environment:
      RABBITMQ_DEFAULT_USER: admin
      RABBITMQ_DEFAULT_PASS: admin123
    networks:
      - microservices-network
    restart: unless-stopped

  # Microservicio de clientes
  clientes-service:
    build: ./clientes-service
    container_name: clientes-service
    ports:
      - "127.0.0.1:8001:8001"
    environment:
      - DATABASE_URL=mysql://user_clientes:clientes123@mysql-clientes:3306/clientes_db
      - RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672/
    depends_on:
      - mysql-clientes
      - rabbitmq
    networks:
      - microservices-network
    volumes:
      - ./clientes-service:/app
    restart: unless-stopped

  # Microservicio de pedidos
  pedidos-service:
    build: ./pedidos-service
    container_name: pedidos-service
    ports:
      - "127.0.0.1:8002:8002"
    environment:
      - DATABASE_URL=postgresql://user_pedidos:pedidos123@postgres-pedidos:5432/pedidos_db
      - RABBITMQ_URL=amqp://admin:admin123@rabbitmq:5672/
      - CLIENTES_SERVICE_URL=http://clientes-service:8001
    depends_on:
      - postgres-pedidos
      - rabbitmq
      - clientes-service
    networks:
      - microservices-network
    volumes:
      - ./pedidos-service:/app
    restart: unless-stopped

networks:
  microservices-network:
    driver: bridge

volumes:
  mysql_clientes_data:
  postgres_pedidos_data:
